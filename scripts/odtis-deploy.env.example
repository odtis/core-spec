# Copy to scripts/odtis-deploy.env and adjust (odtis-deploy.env is gitignored).
#
#   cp scripts/odtis-deploy.env.example scripts/odtis-deploy.env

# Amazon Linux EC2 user + public IP or hostname
ODTIS_EC2_HOST="ec2-user@YOUR_EC2_PUBLIC_IP"

# Path to your SSH private key (.pem)
ODTIS_SSH_KEY="$HOME/.ssh/your-deploy-key.pem"

# Docroot on the server (default is fine for odtis.org vhost)
ODTIS_REMOTE_DIR="/var/www/odtis.org"
