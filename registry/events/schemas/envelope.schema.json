{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://odtis.org/odtis/events/envelope.schema.json",
  "title": "ODTIS audit event envelope",
  "description": "Required fields for all ODTIS audit events (ODTIS-0529)",
  "type": "object",
  "required": ["trace_id", "timestamp", "event_id", "event_type", "source"],
  "properties": {
    "trace_id": {
      "type": "string",
      "description": "Correlation ID propagated across services"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "description": "Emitting service identifier"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
